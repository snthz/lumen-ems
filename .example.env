# ┌──────────────────────────────────────────────────────────────┐
# │  Lumen EMS — Variables de entorno                          │
# │  Copia este archivo como .env.local y completa los valores │
# └──────────────────────────────────────────────────────────────┘

# ── ThingsBoard ───────────────────────────────────────────────
# URL base de la API de ThingsBoard (sin slash final).
# TB_API se usa del lado del servidor; NEXT_PUBLIC_TB_API se expone al cliente.
TB_API=https://thingsboard.example.com
NEXT_PUBLIC_TB_API=https://thingsboard.example.com

# ── Customer Groups (obligatorios) ───────────────────────────
# IDs de los Entity Groups de tipo Customer creados en ThingsBoard.
# Cada grupo representa una categoría de clientes en la plataforma.
# Puedes obtener estos IDs desde ThingsBoard → Customers → Groups → copiar el UUID del grupo.
EMS_INDUSTRIES_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EMS_BILLING_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EMS_MULTISITE_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Base de datos (opcional) ─────────────────────────────────
# Si se proporciona, la app usa PostgreSQL para persistir configuración
# y archivos subidos (branding, logos, etc.).
# Si se omite, la app usa almacenamiento basado en archivos JSON
# dentro de DATA_DIR.
# DATABASE_URL=postgres://usuario:contraseña@localhost:5432/lumen_ems

# ── Almacenamiento en disco (opcional) ───────────────────────
# Directorio donde se guardan settings y archivos cuando no hay
# base de datos. Por defecto: /data
# En desarrollo local, puedes usar una carpeta relativa.
# DATA_DIR=./data
